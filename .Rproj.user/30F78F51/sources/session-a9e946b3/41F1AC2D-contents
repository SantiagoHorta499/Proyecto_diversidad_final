## Parte 3. Descargar secuencias desde GenBank

Ahora descargamos las secuencias de *Rana temporaria* disponibles en GenBank. Usaremos el marcador cytb, uno de los más común en estudios de biodiversidad.

```{r}
# Buscar secuencias de cytb de Rana temporaria
busqueda_rt <- entrez_search(
  db = "nucleotide",
  term = "Rana temporaria[ORGN] AND cytb[Gene] AND src lat lon[prop]",
  retmax = 201)
```

```{r}
# Descargar secuencias en formato FASTA
seqs_rt_raw <- entrez_fetch(
  db = "nucleotide",
  id = busqueda_rt$ids,
  rettype = "fasta",
  retmode = "text")

writeLines(seqs_rt_raw, "data/Rana.fasta")
```

```{r}
# Descargar metadatos (formato GenBank completo)
gb_rt_raw <- entrez_fetch(
  db = "nucleotide",
  id = busqueda_rt$ids,
  rettype = "gb",
  retmode = "text")

writeLines(gb_rt_raw, "data/rana_Cytb.gb")
```

### Extraer metadatos geográficos de GenBank

```{r}
# Dividir por registros
registros_rt <- gb_rt_raw %>%
  str_split("(?=LOCUS\\s)", simplify = FALSE) %>%
  unlist()
registros_rt <- registros_rt[nchar(registros_rt) > 100]

# Extraer campos de cada registro
metadatos_rt <- registros_rt %>%
  map_dfr(~ tibble(
        accession = str_extract(
      .x,
      "(?<=ACCESSION\\s{1,10})\\S+"),
    
      pais = str_extract(
      .x,
      '(?<=/geo_loc_name=")[^":]+'), #Se buscó por geo_loc_name y no por country
    
    lat_lon = str_extract(
      .x,
      '(?<=/lat_lon=")[^"]+')
    ))

# Parsear coordenadas
metadatos_rt_coord <- metadatos_rt %>%
  filter(!is.na(lat_lon)) %>%
  mutate(
    lat = as.numeric(str_extract(lat_lon, "[0-9.]+")),
    lat = ifelse(str_detect(lat_lon, "S"), -lat, lat),
    lon = as.numeric(str_extract(lat_lon, "(?<=\\s)[0-9.]+")),
    lon = ifelse(str_detect(lat_lon, "W"), -lon, lon)
  ) %>%
  filter(!is.na(lat), !is.na(lon))

write.csv(metadatos_rt_coord, "data/Rana_metadatos_genbank.csv", row.names = FALSE)
```

