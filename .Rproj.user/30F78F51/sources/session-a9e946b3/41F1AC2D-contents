## Parte 4. Definir regiones geográficas y calcular diversidad

Para relacionar diversidad genética con distribución, necesitamos agrupar las secuencias por regiones geográficas comparables. Vamos a crear una cuadrícula (grid) sobre el área de distribución de la especie:

```{r}
# Leer secuencias
seqs_rt <- readDNAStringSet(
  "data/Rana.fasta")
names(seqs_rt)
```

```{r}
# Preparar las secuencias para el alineamiento
seqs_rt_dna <- DNAStringSet(
  sapply(seqs_rt, function(x) paste(as.character(x), collapse = "")))
alineamiento <- msa(seqs_rt, method = "ClustalW")

writeXStringSet(
  as(alineamiento, "DNAStringSet"),
  filepath = "data/alineamiento_rt.fasta")

seq_matriz <- read.dna(
  "data/alineamiento_rt.fasta",
  format = "fasta")

rownames(seq_matriz)
dim(seq_matriz)
dist.dna(seq_matriz)

```

Vamos a asignar cada secuencia a una celda de cuadrícula de 5° × 5°:

```{r}
# Crear celdas de 5 grados sobre las coordenadas disponibles
metadatos_rt_coord <- metadatos_rt_coord %>%
  mutate(
    celda_lat = floor(lat / 5) * 5,
    celda_lon = floor(lon / 5) * 5,
    celda_id = paste0(celda_lat, "_", celda_lon)
  )

table(metadatos_rt_coord$celda_id)
```

Calculamos π por celda (mínimo 3 secuencias):

```{r}
ids_seqs_rt <- rownames(seq_matriz)

acc_seqs_rt <- str_extract(
  ids_seqs_rt,
  "^[A-Z]{1,2}[0-9]+")

indices_match_rt <- match(
  acc_seqs_rt,
  metadatos_rt_coord$accession)

celdas_seqs <- metadatos_rt_coord$celda_id[
  indices_match_rt]

lat_celdas <- metadatos_rt_coord$celda_lat[
  indices_match_rt]

lon_celdas <- metadatos_rt_coord$celda_lon[
  indices_match_rt]

celdas_validas <- names(
  which(table(celdas_seqs) >= 3))

diversidad_celdas <- map_dfr(
  celdas_validas,
  function(c) {
    
    idx <- which(celdas_seqs == c)
    
    # usar seq_matriz
    sub_matrix <- seq_matriz[idx, ]
    
    dist_sub <- dist.dna(
      sub_matrix,
      model = "K80",
      pairwise.deletion = TRUE)
    
    pi_celda <- mean(
      as.vector(dist_sub),
      na.rm = TRUE)
    
    tibble(
      celda_id = c,
      celda_lat = lat_celdas[idx[1]],
      celda_lon = lon_celdas[idx[1]],
      n_seqs = length(idx),
      pi = pi_celda)
  }
)

print(diversidad_celdas)
write.csv(diversidad_celdas, "output/diversidad_por_celda.csv", row.names = FALSE)
```

