## Parte 5. Calcular densidad de registros de iNaturalist por celda

```{r}
# Asignar celdas a los registros de iNaturalist
data_rt_limpio <- data_rt_limpio %>%
  mutate(
    celda_lat = floor(decimalLatitude / 5) * 5,
    celda_lon = floor(decimalLongitude / 5) * 5,
    celda_id = paste0(celda_lat, "_", celda_lon)
  )

# Contar registros por celda
densidad_celdas <- data_rt_limpio %>%
  group_by(celda_id, celda_lat, celda_lon) %>%
  summarise(
    n_registros = n(),
    n_anios = n_distinct(year),
    .groups = "drop"
  )

head(densidad_celdas)
```

Unimos diversidad y densidad:

```{r}
datos_analisis2 <- inner_join(diversidad_celdas, 
                              densidad_celdas, by = "celda_id") %>%
  select(celda_id, celda_lat = celda_lat.x, celda_lon = celda_lon.x,
         n_seqs, pi, n_registros, n_anios)

print(datos_analisis2)
write.csv(datos_analisis2, "output/diversidad_vs_distribucion.csv", row.names = FALSE)
```

