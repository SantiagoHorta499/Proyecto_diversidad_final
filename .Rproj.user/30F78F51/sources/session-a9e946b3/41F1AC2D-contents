inat_sf <- st_as_sf(data_rt_limpio,
                    coords = c("decimalLongitude", "decimalLatitude"),
                    crs = 4326)

genbank_sf <- st_as_sf(metadatos_rt_coord,
                       coords = c("lon", "lat"),
                       crs = 4326)

# Mapa de comparación
p6 <- ggplot() +
  geom_sf(data = mundo, fill = "grey90", color = "grey60", size = 0.3) +
  geom_sf(data = inat_sf, color = "#00B4D8", size = 1, alpha = 0.3,
          aes(shape = "iNaturalist")) +
  geom_sf(data = genbank_sf, color = "#EF233C", size = 2.5,
          aes(shape = "GenBank")) +
  scale_shape_manual(
    values = c("iNaturalist" = 16, "GenBank" = 17),
    name = "Fuente"
  ) +
  coord_sf(xlim = c(bbox["xmin"], bbox["xmax"]),
           ylim = c(bbox["ymin"], bbox["ymax"])) +
  labs(x = "Longitud", y = "Latitud",
    caption = paste("iNaturalist:", nrow(data_rt_limpio),
                    "registros | GenBank:", nrow(metadatos_rt_coord), 
